{
  "name": "@riavzon/jwtauth",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "require": "./dist/main.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && cp -R src/jwtAuth/emails dist/jwtAuth && cp src/global.d.ts dist/global.d.ts && cp src/jwtAuth/utils/disposable_email_blocklist.conf dist/jwtAuth/utils && cp src/jwtAuth/models/useragent.csv dist/jwtAuth/models",

    "build:prod": "tsc -p tsconfig.prod.json && cp -R src/jwtAuth/emails dist/jwtAuth && cp src/global.d.ts dist/global.d.ts && cp src/jwtAuth/utils/disposable_email_blocklist.conf dist/jwtAuth/utils && cp src/jwtAuth/models/useragent.csv dist/jwtAuth/models",
    
    "build:createTables": "node dist/jwtAuth/models/schema.js",
    "docs:start": "typedoc --options ./typedoc.json && vitepress dev",
    "prepack": "npm run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "docs:dev": "vitepress dev",
    "docs:build": "vitepress build",
    "docs:preview": "vitepress preview"
  },
  "dependencies": {
    "@riavzon/botdetector": "git+ssh://git@github.com:Sergo706/botDetector.git#main",
    "@types/cookie-parser": "^1.4.8",
    "@types/date-fns": "^2.5.3",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.1",
    "@types/he": "^1.2.3",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/sanitize-html": "^2.16.0",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "he": "^1.2.0",
    "ip-range-check": "^0.2.0",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.1.0",
    "mysql2": "^3.14.0",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "rate-limiter-flexible": "^7.0.0",
    "resend": "^6.0.1",
    "sanitize-html": "^2.17.0",
    "telegraf": "^4.16.3",
    "ts-node": "^10.9.2",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.0.13",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "dotenv": "^17.2.2",
    "typedoc": "^0.28.9",
    "typedoc-plugin-markdown": "^4.8.0",
    "vitepress": "^1.6.3",
    "vitest": "^3.2.4"
  }
}
