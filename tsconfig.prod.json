{
    "compilerOptions": {
    "target": "ES2020",
    "resolveJsonModule": true,   
    "rootDir": "./src",
    "outDir": "./dist",                          
    "module": "NodeNext",   
     "moduleResolution": "nodenext",                                                   
     "allowSyntheticDefaultImports": true,            
    "esModuleInterop": true,                           
    "forceConsistentCasingInFileNames": true,           
    "strict": true,                                      
    "skipLibCheck": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true                            
  },
  "include": ["src/**/*",  "src/**/*.json", "src/global.d.ts"],
  "exclude": ["node_modules"]
}
