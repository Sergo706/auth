<!DOCTYPE html>
<html lang="en">
<body style="margin:0; padding:0; background-color:#0e0d0d; color:#dbdede; font-family:Helvetica, Arial, sans-serif;">

  <!-- HEADER (logo) -->
  <table width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color:#1a1919;">
    <tr>
      <td align="left" style="padding:10px 0 15px 40px;">
        <a href="https://riavzon.com/" style="text-decoration:none;">
          <img 
            src="https://media.riavzon.com/favicon-1.png" 
            alt="logo" 
            width="80" 
            style="display:block; border:0; outline:none; text-decoration:none;" 
          />
        </a>
      </td>
    </tr>
    <!-- blue bar under header -->
    <tr>
      <td style="background-color:#688cfa; height:1px; line-height:1px; font-size:0; width: 95%;">&nbsp;</td>
    </tr>
  </table>

  <!-- MAIN CONTENT -->
  <table width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color:#0e0d0d;">
    <tr>
      <td align="center" style="padding:40px 20px;">
        <!-- container wrapper -->
        <table width="600" border="0" cellspacing="0" cellpadding="0" style="width:100%; max-width:600px;">
          <tr>
            <td align="center" style="position:relative;">
              <!-- “background circle” (optional) -->
              <!-- Some clients won’t show it; you can drop or inline as image if needed -->
            </td>
          </tr>
          <tr>
            <td align="center" style="padding-top:20px;">
              <!-- Main image -->
              <img 
                src="<%= images[0].path %>" 
                alt="<%= images[0].alt %>" 
                title="<%= images[0].name %>" 
                width="500" 
                style="display:block; width:80%; max-width:500px; height:auto; border:0; outline:none; text-decoration:none;"
              />
            </td>
          </tr>
          <tr>
            <td align="center" style="padding:20px 0;">
              <!-- Subject line -->
              <h1 style="margin:0; font-size:28px; line-height:32px; color:#dbdede; text-align:center;">
                <%= headers.headerOne %>
              </h1>
            </td>
          </tr>
          <tr>
            <td align="left" style="padding:20px 0;">
              <!-- Secondary Header -->
              <h2 style="margin:0; font-size:22px; line-height:26px; color:#dbdede;">
                <%= headers.headerTwo %>
              </h2>
            </td>
          </tr>

          <% if (typeof code !== 'undefined' && code) { %>
          <tr>
            <td align="center" style="padding:20px 0;">
              <!-- Code block -->
              <div style="
                display:inline-block;
                padding:10px;
                border:2px dashed white;
                color:#dbdede;
                font-size:18px;
                letter-spacing:4px;
                background-color:rgba(209,212,214,0.2);
                ">
                <%= code %>
              </div>
            </td>
          </tr>
          <% } %>

          <tr>
            <td align="left" style="padding:20px 0;">
              <!-- Main message -->
              <p style="margin:0; font-size:16px; line-height:24px; color:#dbdede;">
                Hi <strong><%= userName %></strong>, <%= message %>
              </p>
            </td>
          </tr>

          <% if (link) { %>
          <tr>
            <td align="center" style="padding:30px 0;">
              <!-- Button row (using tables for layout) -->
              <table border="0" cellspacing="0" cellpadding="0">
                <tr>
                  <% link.forEach(el => { %>
                    <td style="padding:0 10px;">
                      <a href="<%= el.path %>" style="
                        display:inline-block;
                        text-decoration:none;
                        background-color:#2F48D5;
                        color:#ffffff;
                        padding:10px 20px;
                        border-radius:25px;
                        font-size:16px;
                        ">
                        <%= el.label %>
                      </a>
                    </td>
                  <% }); %>
                </tr>
              </table>
            </td>
          </tr>
          <% } %>

        </table>
      </td>
    </tr>
  </table>

  <!-- FOOTER -->
  <table width="100%" border="0" cellspacing="0" cellpadding="0" style="background-color:#0c0c0c;">
    <tr>
      <td align="center" style="padding:20px 0;">
        <!-- Links -->
        <table width="600" border="0" cellspacing="0" cellpadding="0" style="width:100%; max-width:600px; text-align:center;">
          <tr>
            <td style="padding-bottom:10px;">
              <a href="https://riavzon.com/" style="color:#cdd1d4; text-decoration:none; font-size:14px; margin:0 10px;">Home</a> |
              <a href="https://riavzon.com/dashboard" style="color:#cdd1d4; text-decoration:none; font-size:14px; margin:0 10px;">Account</a> |
              <a href="https://riavzon.com/contact" style="color:#cdd1d4; text-decoration:none; font-size:14px; margin:0 10px;">Contact</a>
            </td>
          </tr>
          <tr>
            <td>
              <!-- Social icons -->
              <a href="#" style="display:inline-block; margin:0 5px;">
                <img src="https://media.riavzon.com/image-6.png" alt="" width="24" style="display:block; border:0; outline:none; text-decoration:none;" />
              </a>
              <a href="#" style="display:inline-block; margin:0 5px;">
                <img src="https://media.riavzon.com/image-5.png" alt="" width="24" style="display:block; border:0; outline:none; text-decoration:none;" />
              </a>
              <a href="#" style="display:inline-block; margin:0 5px;">
                <img src="https://media.riavzon.com/image-3.png" alt="" width="24" style="display:block; border:0; outline:none; text-decoration:none;" />
              </a>
            </td>
          </tr>
          <tr>
            <td style="padding-top:10px; color:#cdd1d4; font-size:12px;">
              &copy; All Rights Reserved Sergio Riavzon 2025
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

</body>
</html>
